{
	"name": "bring-the-firm",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"builder-sdk:build": "npm --prefix packages/builder-sdk run build",
		"builder-sdk:check": "node scripts/check-builder-sdk-sync.mjs && npm run builder-sdk:build",
		"dev": "npm run builder-sdk:build && vite dev",
		"build": "npm run builder-sdk:build && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "npm run builder-sdk:check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "npm run builder-sdk:build && eslint ."
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-vercel": "^6.0.7",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22.18.10",
		"eslint": "^9.39.2",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@overbase/builder-sdk": "file:packages/builder-sdk"
	},
	"overrides": {
		"cookie": "^0.7.2"
	}
}
